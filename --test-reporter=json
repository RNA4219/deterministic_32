import fs from "node:fs";
import path from "node:path";
import process from "node:process";
import { spawn } from "node:child_process";
import { fileURLToPath } from "node:url";

const scriptPath = fileURLToPath(import.meta.url);
const projectRoot = path.dirname(scriptPath);
const defaultTargets = ["dist/tests", "dist/frontend/tests"];
const defaultDestination = "logs/test.jsonl";
const testSkipPatternFlag = "--test-skip-pattern";
const compiledTestFilePattern = /(?:\.spec|\.test)\.(?:[cm]?js)$/u;
const testSegmentPattern = /^(?:tests|__tests__)$|(?:\.spec(?:\.[^.]+)?$)|(?:\.test(?:\.[^.]+)?$)/u;
const flagsWithValues = new Set([
  "--conditions",
  "--env-file",
  "--eval",
  "--experimental-loader",
  "--experimental-specifier-resolution",
  "--import",
  "--input-type",
  "--loader",
  "--print",
  "--require",
  "--test-concurrency",
  "--test-name-pattern",
  "--test-ignore",
  "--test-match",
  "--test-runner",
  "--test-reporter",
  "--test-reporter-destination",
  testSkipPatternFlag,
  "--test-timeout",
  "--watch-path",
  "-i",
  "-r",
]);

const sourceDirectories = defaultTargets.map((target) => {
  const relativeFromDist = path.relative("dist", target);
  return path.join(projectRoot, relativeFromDist);
});

const unique = (values) => {
  const seen = new Set();
  const result = [];
  for (const value of values) {
    if (seen.has(value)) {
      continue;
    }
    seen.add(value);
    result.push(value);
  }
  return result;
};

const resolveProjectRelative = (value) => {
  const relative = path.relative(projectRoot, value);
  if (relative === "" || relative.startsWith("..") || path.isAbsolute(relative)) {
    return null;
  }
  return relative.replace(/\\+/g, "/");
};

export const resolveDestination = (override = null) => {
  if (override === null || override === "") {
    return path.resolve(projectRoot, defaultDestination);
  }
  return path.isAbsolute(override)
    ? override
    : path.resolve(projectRoot, override);
};

const ensureDefaultTargets = (existsSync, fallbackTargets) => {
  const effectiveDefaults = fallbackTargets ?? defaultTargets;
  return effectiveDefaults.filter((target) => {
    const absolute = path.resolve(projectRoot, target);
    return existsSync(target) || existsSync(absolute);
  });
};

const mapTsTarget = (projectRelativePath) => {
  if (projectRelativePath.endsWith(".cts")) {
    return `dist/${projectRelativePath.slice(0, -4)}.cjs`;
  }
  if (projectRelativePath.endsWith(".mts")) {
    return `dist/${projectRelativePath.slice(0, -4)}.mjs`;
  }
  if (projectRelativePath.endsWith(".ts")) {
    return `dist/${projectRelativePath.slice(0, -3)}.js`;
  }
  return null;
};

const mapArgument = (argument, existsSync, forceTarget = false) => {
  const argumentSegments = argument
    .split(/[\\/]/u)
    .filter((segment) => segment !== "" && segment !== ".");
  const looksLikeTestTarget = argumentSegments.some((segment) => testSegmentPattern.test(segment));

  if (!forceTarget && argument.startsWith("--") && !looksLikeTestTarget) {
    return { value: argument, isTarget: false };
  }

  const bases = path.isAbsolute(argument)
    ? [""]
    : unique([process.cwd(), ...sourceDirectories, projectRoot]);

  let matchedAbsolutePath = null;
  let matchedRelativePath = null;
  let matchedPathExists = false;

  for (const base of bases) {
    const candidate = path.isAbsolute(argument)
      ? argument
      : path.resolve(base, argument);
    const relative = resolveProjectRelative(candidate);
    if (relative === null) {
      continue;
    }

    if (existsSync(candidate) || existsSync(relative)) {
      matchedAbsolutePath = candidate;
      matchedRelativePath = relative;
      matchedPathExists = true;
      break;
    }

    if (matchedAbsolutePath === null) {
      matchedAbsolutePath = candidate;
      matchedRelativePath = relative;
    }
  }

  if (matchedRelativePath === null) {
    return { value: argument, isTarget: forceTarget };
  }

  const pathSegments = matchedRelativePath.split("/");
  const hasTestSegment = pathSegments.some((segment) => testSegmentPattern.test(segment));
  if (!hasTestSegment) {
    return { value: argument, isTarget: forceTarget };
  }

  const mappedTsTarget = mapTsTarget(matchedRelativePath);
  if (mappedTsTarget !== null) {
    return { value: mappedTsTarget, isTarget: true };
  }

  const mappedDirectoryCandidate =
    matchedRelativePath === "dist" || matchedRelativePath.startsWith("dist/")
      ? matchedRelativePath
      : `dist/${matchedRelativePath}`;
  const mappedDirectoryAbsolute = path.resolve(projectRoot, mappedDirectoryCandidate);

  if (matchedPathExists || existsSync(mappedDirectoryCandidate) || existsSync(mappedDirectoryAbsolute)) {
    try {
      const statCandidates = unique([
        matchedAbsolutePath,
        path.resolve(projectRoot, matchedRelativePath),
        mappedDirectoryAbsolute,
      ].filter((value) => typeof value === "string"));

      for (const candidate of statCandidates) {
        if (!fs.existsSync(candidate)) {
          continue;
        }
        if (fs.statSync(candidate).isDirectory()) {
          return { value: mappedDirectoryCandidate, isTarget: true };
        }
      }
    } catch {
      // ignore and fall through
    }
  }

  return { value: matchedRelativePath, isTarget: true };
};

export const prepareRunnerOptions = (argv, overrides = {}) => {
  const existsSync = overrides.existsSync ?? ((candidate) => fs.existsSync(candidate));
  const fallbackTargets = overrides.defaultTargets ?? defaultTargets;
  const cliArguments = argv.slice(2);
  const passthroughArgs = [];
  const targets = [];
  let destinationOverride = null;
  let pendingFlag = null;
  let forceTargetMode = false;

  const consumePendingFlag = (value) => {
    if (pendingFlag === null) {
      return false;
    }

    if (pendingFlag === "--test-reporter-destination") {
      destinationOverride = value;
    } else {
      passthroughArgs.push(pendingFlag, value);
    }
    pendingFlag = null;
    return true;
  };

  for (const argument of cliArguments) {
    if (argument === "--") {
      if (pendingFlag !== null) {
        throw new RangeError(`Missing value for ${pendingFlag}`);
      }
      forceTargetMode = true;
      continue;
    }

    if (consumePendingFlag(argument)) {
      continue;
    }

    if (flagsWithValues.has(argument)) {
      pendingFlag = argument;
      continue;
    }

    const mapped = mapArgument(argument, existsSync, forceTargetMode);
    if (mapped.isTarget) {
      targets.push(mapped.value);
    } else {
      passthroughArgs.push(mapped.value);
      if (flagsWithValues.has(mapped.value)) {
        pendingFlag = mapped.value;
      }
    }
  }

  if (pendingFlag !== null) {
    throw new RangeError(`Missing value for ${pendingFlag}`);
  }

  return {
    passthroughArgs,
    targets: unique(targets.length > 0 ? targets : ensureDefaultTargets(existsSync, fallbackTargets)),
    destinationOverride,
  };
};

const collectCompiledTestFiles = (directory) => {
  const entries = fs
    .readdirSync(path.resolve(projectRoot, directory), { withFileTypes: true })
    .sort((left, right) => left.name.localeCompare(right.name));
  const files = [];

  for (const entry of entries) {
    const relativePath = path.posix.join(directory.replace(/\\+/g, "/"), entry.name);
    if (entry.isDirectory()) {
      files.push(...collectCompiledTestFiles(relativePath));
      continue;
    }
    if (entry.isFile() && compiledTestFilePattern.test(entry.name)) {
      files.push(relativePath);
    }
  }

  return files;
};

const expandTargets = (targets) => {
  const expanded = [];
  for (const target of targets) {
    const absolute = path.resolve(projectRoot, target);
    if (!fs.existsSync(absolute)) {
      expanded.push(target);
      continue;
    }
    try {
      if (fs.statSync(absolute).isDirectory()) {
        const files = collectCompiledTestFiles(target);
        expanded.push(...(files.length > 0 ? files : [target]));
        continue;
      }
    } catch {
      // ignore and fall through
    }
    expanded.push(target);
  }
  return unique(expanded);
};

export const runJsonReporter = ({ argv = process.argv, spawnImpl } = {}) => {
  const { passthroughArgs, targets, destinationOverride } = prepareRunnerOptions(argv);
  const destination = resolveDestination(destinationOverride);
  fs.mkdirSync(path.dirname(destination), { recursive: true });

  const args = [
    "--test",
    "--test-reporter",
    "json",
    `--test-reporter-destination=${destination}`,
    ...expandTargets(targets),
    ...passthroughArgs,
  ];

  const child = (spawnImpl ?? globalThis.__CAT32_TEST_SPAWN__ ?? spawn)(
    process.execPath,
    args,
    { cwd: projectRoot, stdio: "inherit" },
  );

  const signalHandlers = new Map();
  const cleanup = () => {
    for (const [signal, handler] of signalHandlers) {
      process.removeListener(signal, handler);
    }
  };

  for (const signal of ["SIGINT", "SIGTERM", "SIGQUIT"]) {
    const handler = () => {
      if (typeof child.kill === "function") {
        child.kill(signal);
      }
    };
    signalHandlers.set(signal, handler);
    process.on(signal, handler);
  }

  child.once("exit", (code, signal) => {
    cleanup();
    if (signal) {
      process.kill(process.pid, signal);
      return;
    }
    process.exit(code ?? 0);
  });

  child.once("error", (error) => {
    cleanup();
    throw error;
  });

  return child;
};

if (process.env.__CAT32_SKIP_JSON_REPORTER_RUN__ !== "1") {
  const entryScriptPath = path.resolve(process.argv[1] ?? "");
  const entryScriptName = path.basename(process.argv[1] ?? "");
  if (entryScriptPath === scriptPath || entryScriptName === path.basename(scriptPath)) {
    runJsonReporter();
  }
}